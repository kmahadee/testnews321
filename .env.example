# ==============================================================================
# Automated AI News Reel SaaS - Environment Configuration Template
# ==============================================================================

# Core Application URL
# Used for OAuth redirect routing and self-referential links.
APP_URL="https://your-domain.com"

# Gemini API Authentication
# Required to trigger real-time Google search grounding, news summary, script formulation, and slide generation.
GEMINI_API_KEY="AIzaSy..."

# OpenAI API Authentication (Optional)
# Can be supplied as an alternative text generation engine if desired.
OPENAI_API_KEY="sk-proj-..."

# ------------------------------------------------------------------------------
# Facebook Graph API Integrations (OAuth Login & Publishing)
# Create a Facebook Developer App with "pages_manage_posts" and "pages_read_engagement" permissions.
# ------------------------------------------------------------------------------
FACEBOOK_CLIENT_ID="your_facebook_client_id"
FACEBOOK_CLIENT_SECRET="your_facebook_client_secret"

# ------------------------------------------------------------------------------
# Google Gmail API Integrations (OAuth Sender & Deliverability)
# Create a Google Cloud Project with the Gmail API enabled, and configure an OAuth client.
# ------------------------------------------------------------------------------
GMAIL_CLIENT_ID="your_google_gmail_client_id"
GMAIL_CLIENT_SECRET="your_google_gmail_client_secret"
